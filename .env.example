# Database (MongoDB — replica set required by Prisma; Docker Compose sets up rs0)
# directConnection=true: app on host talks to single-node RS exposed on localhost
DATABASE_URL=mongodb://127.0.0.1:27017/seoaifrog?replicaSet=rs0&directConnection=true

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
SESSION_SECRET=change-me-to-32-plus-random-chars-minimum

# OpenAI
OPENAI_MODEL=gpt-4o

# API
PORT=3001
FRONTEND_URL=http://localhost:5173
STORAGE_PATH=./storage
