DATABASE_URL=mongodb://127.0.0.1:27017/seoaifrog?replicaSet=rs0&directConnection=true
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me-to-32-plus-random-chars-minimum
# 32-byte hex secret for encrypting per-user OpenAI keys at rest (required to save/test saved keys)
# ACCOUNT_ENCRYPTION_KEY=
OPENAI_MODEL=gpt-4o
# Embed crawl text for audits (default on). Set to 0 to use the older “sample many pages” payloads only.
# AUDIT_USE_EMBEDDINGS=0
# Re-embed every audit even if page count unchanged: AUDIT_EMBEDDING_REFRESH=1
# AUDIT_EMBEDDING_TOP_K=32
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI request/response NDJSON: on in production; for local dev add OPENAI_AUDIT_LOG=1
# OPENAI_AUDIT_LOG=1
# OPENAI_AUDIT_LOG_DIR=D:\absolute\path\to\logs
PORT=3001
FRONTEND_URL=http://localhost:5173
STORAGE_PATH=./storage
